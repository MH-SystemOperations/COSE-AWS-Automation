{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ProdSysOpsElevatedWrite",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateFunction",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:DeleteFunction",
        "lambda:PublishVersion",
        "lambda:CreateAlias",
        "lambda:UpdateAlias",
        "lambda:DeleteAlias",
        "lambda:PublishLayerVersion",
        "lambda:DeleteLayerVersion",
        "lambda:PutFunctionConcurrency",
        "lambda:DeleteFunctionConcurrency",
        "lambda:TagResource",
        "lambda:UntagResource",
        "lambda:PutFunctionEventInvokeConfig",
        "lambda:UpdateFunctionEventInvokeConfig",
        "lambda:DeleteFunctionEventInvokeConfig",
        "cloudformation:*",
        "apigateway:*",
        "execute-api:*",
        "ecr:*",
        "ecs:*",
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:DeleteParameters",
        "ssm:AddTagsToResource",
        "ssm:RemoveTagsFromResource",
        "ssm:LabelParameterVersion",
        "xray:*",
        "events:*",
        "scheduler:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/mh:environment": ["prod", "production"],
          "aws:RequestedRegion": "us-east-1"
        }
      }
    },
    {
      "Sid": "ProdSysOpsElevatedIam",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:CreatePolicy",
        "iam:DeletePolicy",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:UpdateRole",
        "iam:UpdateRoleDescription"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/mh:environment": ["prod", "production"]
        },
        "StringLike": {
          "iam:PermissionsBoundary": "arn:aws:iam::*:policy/dev_boundary"
        }
      }
    },
    {
      "Sid": "ProdDenyLambdaUnsafe",
      "Effect": "Deny",
      "Action": [
        "lambda:Add*",
        "lambda:*FunctionUrlConfig"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/mh:environment": ["prod", "production"]
        }
      }
    },
    {
      "Sid": "ProdDenyCloudFormationUnsafe",
      "Effect": "Deny",
      "Action": [
        "cloudformation:*Typ*",
        "cloudformation:*OrganizationsAccess"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/mh:environment": ["prod", "production"]
        }
      }
    }
  ]
}
