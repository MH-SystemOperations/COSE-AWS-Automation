{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CoreReadOnlyAccess",
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*",
        "ec2:Get*",
        "rds:Describe*",
        "rds:ListTagsForResource",
        "s3:Get*",
        "s3:List*",
        "lambda:Get*",
        "lambda:List*",
        "dynamodb:DescribeTable",
        "dynamodb:ListTables",
        "dynamodb:DescribeBackup",
        "dynamodb:ListBackups",
        "ecs:Describe*",
        "ecs:List*",
        "ecr:Describe*",
        "ecr:List*",
        "ecr:GetAuthorizationToken",
        "cloudformation:Describe*",
        "cloudformation:Get*",
        "cloudformation:List*",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "cloudwatch:List*",
        "logs:Describe*",
        "logs:Get*",
        "logs:List*",
        "events:Describe*",
        "events:List*",
        "scheduler:Get*",
        "scheduler:List*",
        "sns:Get*",
        "sns:List*",
        "sqs:Get*",
        "sqs:List*",
        "glue:Get*",
        "glue:List*",
        "athena:Get*",
        "athena:List*",
        "databrew:Describe*",
        "databrew:List*",
        "states:Describe*",
        "states:List*",
        "states:Get*",
        "airflow:Get*",
        "airflow:List*",
        "kms:Describe*",
        "kms:Get*",
        "kms:List*",
        "ssm:Describe*",
        "ssm:Get*",
        "ssm:List*",
        "secretsmanager:ListSecrets",
        "secretsmanager:DescribeSecret",
        "cognito-idp:Describe*",
        "cognito-idp:List*",
        "apigateway:GET",
        "elasticloadbalancing:Describe*",
        "autoscaling:Describe*",
        "xray:Get*",
        "xray:BatchGet*",
        "wafv2:Get*",
        "wafv2:List*",
        "wafv2:Describe*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "IAMLimitedRead",
      "Effect": "Allow",
      "Action": [
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:ListRoles",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListPolicies",
        "iam:ListPolicyVersions"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyAIServices",
      "Effect": "Deny",
      "Action": [
        "bedrock:*",
        "sagemaker:*",
        "comprehend:*",
        "rekognition:*",
        "textract:*",
        "translate:*",
        "polly:*",
        "transcribe:*",
        "lex:*",
        "personalize:*",
        "forecast:*",
        "kendra:*"
      ],
      "Resource": "*"
    }
  ]
}
