{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DevQaStageFullWrite",
      "Effect": "Allow",
      "Action": [
        "lambda:*",
        "cloudformation:*",
        "s3:*",
        "sqs:*",
        "sns:*",
        "dynamodb:*",
        "glue:*",
        "athena:*",
        "databrew:*",
        "airflow:*",
        "states:*",
        "cloudwatch:*",
        "logs:*",
        "secretsmanager:*",
        "events:*",
        "scheduler:*",
        "apigateway:*",
        "execute-api:*",
        "cognito-idp:*",
        "ecr:*",
        "ecs:*",
        "kms:*",
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:DeleteParameters",
        "ssm:AddTagsToResource",
        "ssm:RemoveTagsFromResource",
        "ssm:LabelParameterVersion",
        "xray:*",
        "wafv2:GetWebACL",
        "wafv2:ListWebACLs",
        "wafv2:AssociateWebACL",
        "wafv2:DisassociateWebACL"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:ResourceTag/mh:environment": ["prod", "production"]
        },
        "StringEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    },
    {
      "Sid": "SandboxFullAccess",
      "Effect": "Allow",
      "Action": "*",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceAccount": "123185598779"
        }
      }
    },
    {
      "Sid": "DevQaStageIamScoped",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:CreatePolicy",
        "iam:DeletePolicy",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:PassRole",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:UpdateRole",
        "iam:UpdateRoleDescription"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:ResourceTag/mh:environment": ["prod", "production"]
        },
        "StringLike": {
          "iam:PermissionsBoundary": "arn:aws:iam::*:policy/dev_boundary"
        }
      }
    },
    {
      "Sid": "DevQaDenyLambdaUnsafe",
      "Effect": "Deny",
      "Action": [
        "lambda:Add*",
        "lambda:*FunctionUrlConfig"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalAccount": [
            "201799325713",
            "808468589041",
            "686255955782",
            "593793032905"
          ]
        }
      }
    },
    {
      "Sid": "DevQaDenyCloudFormationUnsafe",
      "Effect": "Deny",
      "Action": [
        "cloudformation:*Typ*",
        "cloudformation:*OrganizationsAccess"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalAccount": [
            "201799325713",
            "808468589041",
            "686255955782",
            "593793032905"
          ]
        }
      }
    },
    {
      "Sid": "DenyTerraformBucket",
      "Effect": "Deny",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::marathonhealth-terraform",
        "arn:aws:s3:::marathonhealth-terraform/*"
      ]
    },
    {
      "Sid": "ProdOperationalWrite",
      "Effect": "Allow",
      "Action": [
        "lambda:InvokeFunction",
        "lambda:InvokeAsync",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:DeleteObjects",
        "s3:PutObjectTagging",
        "s3:DeleteObjectTagging",
        "s3:PutLifecycleConfiguration",
        "sqs:*",
        "cloudwatch:PutDashboard",
        "cloudwatch:DeleteDashboards",
        "cloudwatch:PutMetricFilter",
        "cloudwatch:DeleteMetricFilter",
        "logs:FilterLogEvents",
        "logs:StartLiveTail",
        "logs:StopLiveTail",
        "logs:PutMetricFilter",
        "secretsmanager:GetSecretValue",
        "secretsmanager:ListSecrets",
        "secretsmanager:DescribeSecret",
        "airflow:*",
        "cognito-idp:CreateResourceServer",
        "cognito-idp:UpdateResourceServer",
        "cognito-idp:DeleteResourceServer",
        "cognito-idp:DescribeResourceServer",
        "cognito-idp:UpdateUserPoolClient",
        "cognito-idp:ListUsers",
        "sns:CreateTopic",
        "sns:DeleteTopic",
        "sns:GetTopicAttributes",
        "sns:SetTopicAttributes",
        "glue:StartJobRun",
        "glue:BatchStopJobRun",
        "glue:GetJobRun",
        "athena:StartQueryExecution",
        "athena:StopQueryExecution",
        "athena:GetQueryExecution",
        "databrew:StartJobRun",
        "databrew:StopJobRun",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "states:StartExecution",
        "states:StopExecution",
        "states:DescribeExecution",
        "kms:ListAliases",
        "kms:DescribeKey",
        "kms:Decrypt",
        "kms:GenerateDataKey",
        "ecs:UpdateService",
        "ecs:RunTask",
        "ecs:StopTask"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/mh:environment": ["prod", "production"]
        },
        "StringEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    },
    {
      "Sid": "ProdIamPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/mh:environment": ["prod", "production"]
        },
        "StringLike": {
          "iam:PassedToService": [
            "lambda.amazonaws.com",
            "databrew.amazonaws.com",
            "airflow.amazonaws.com",
            "scheduler.amazonaws.com"
          ]
        }
      }
    }
  ]
}
